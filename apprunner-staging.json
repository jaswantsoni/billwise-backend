{
  "ServiceName": "kampony-backend-staging",
  "SourceConfiguration": {
    "CodeRepository": {
      "RepositoryUrl": "https://github.com/jaswantsoni/billwise-backend",
      "SourceCodeVersion": {
        "Type": "BRANCH",
        "Value": "main"
      },
      "CodeConfiguration": {
        "ConfigurationSource": "API",
        "CodeConfigurationValues": {
          "Runtime": "NODEJS_18",
          "BuildCommand": "npm install && npx prisma generate",
          "StartCommand": "node server.js",
          "Port": "8080",
          "RuntimeEnvironmentVariables": {
            "NODE_ENV": "production",
            "PORT": "8080"
          }
        }
      }
    },
    "AuthenticationConfiguration": {
      "ConnectionArn": "arn:aws:apprunner:us-east-1:342695602806:connection/update_bot/83bf23ab58034e6bac4ff70836edb7cc"
    },
    "AutoDeploymentsEnabled": true
  },
  "InstanceConfiguration": {
    "Cpu": "0.25 vCPU",
    "Memory": "0.5 GB"
  },
  "HealthCheckConfiguration": {
    "Protocol": "HTTP",
    "Path": "/health",
    "Interval": 10,
    "Timeout": 5,
    "HealthyThreshold": 1,
    "UnhealthyThreshold": 5
  },
  "AutoScalingConfigurationArn": ""
}
